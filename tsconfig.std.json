{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": true
    },
    "include": [
        "src/std/**/*.mts"
    ]
}
