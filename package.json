{
    "name": "@lapis-lang/lapis-js",
    "version": "0.51.0",
    "description": "An embedded DSL for experimentation of Lapis Semantics",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./io": {
            "types": "./dist/lib/io/index.d.mts",
            "import": "./dist/lib/io/index.mjs"
        },
        "./std": {
            "types": "./dist/std/index.d.mts",
            "import": "./dist/std/index.mjs"
        },
        "./std/protocols/*": {
            "types": "./dist/std/protocols/*.d.mts",
            "import": "./dist/std/protocols/*.mjs"
        },
        "./std/data/*": {
            "types": "./dist/std/data/*.d.mts",
            "import": "./dist/std/data/*.mjs"
        },
        "./std/behavior/*": {
            "types": "./dist/std/behavior/*.d.mts",
            "import": "./dist/std/behavior/*.mjs"
        },
        "./std/primitive/*": {
            "types": "./dist/std/primitive/*.d.mts",
            "import": "./dist/std/primitive/*.mjs"
        },
        "./std/derive/*": {
            "types": "./dist/std/derive/*.d.mts",
            "import": "./dist/std/derive/*.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "keywords": [
        "algebraic-data-types",
        "adt",
        "codata",
        "functional-programming",
        "pattern-matching",
        "fold",
        "unfold",
        "catamorphism",
        "anamorphism",
        "lapis"
    ],
    "scripts": {
        "prebuild": "npm run typecheck && npm run lint:fix",
        "build": "webpack",
        "postbuild": "tsc --emitDeclarationOnly && tsc -p tsconfig.io.json && tsc -p tsconfig.std.json && cpy \"dist-io/lib/io/*\" dist/lib/io && rimraf dist-io",
        "typecheck": "tsc --noEmit",
        "typecheck:tests": "tsc --noEmit --project tsconfig.test.json",
        "lint": "eslint .",
        "lint:tests": "eslint \"src/tests/**/*.mts\" \"examples/**/*.mts\"",
        "lint:fix": "eslint . --fix",
        "lint:fix:tests": "eslint --fix \"src/tests/**/*.mts\" \"examples/**/*.mts\"",
        "pretest": "npm run build",
        "test": "globstar -- node --import tsx --test ./src/tests/*.test.mts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lapis-lang/lapis-js.git"
    },
    "author": "Michael L Haufe <tno@thenewobjective.com> (https://thenewobjective.com)",
    "license": "AGPL-3.0-only",
    "bugs": {
        "url": "https://github.com/lapis-lang/lapis-js/issues"
    },
    "homepage": "https://github.com/lapis-lang/lapis-js#readme",
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@eslint/json": "^0.14.0",
        "@eslint/markdown": "^7.5.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^24.10.1",
        "cpy-cli": "^7.0.0",
        "eslint": "^9.39.1",
        "eslint-webpack-plugin": "^5.0.2",
        "globals": "^16.5.0",
        "globstar": "^1.0.0",
        "rimraf": "^6.1.3",
        "ts-loader": "^9.5.4",
        "ts-morph": "^27.0.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "webpack": "^5.102.1",
        "webpack-cli": "^6.0.1"
    },
    "files": [
        "dist"
    ]
}
