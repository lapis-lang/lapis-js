{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "allowJs": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.mts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/tests/**",
        "examples/**"
    ]
}